{
  "info": {
    "name": "RSVP API",
    "description": "RSVP Event Attendance System - Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "authToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "eventId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/",
            "description": "Basic server check"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Health endpoint for monitoring"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/createuser",
            "header": [{ "key": "Content-Type", "value": "multipart/form-data" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Test User", "type": "text" },
                { "key": "email", "value": "test@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.authToken) { pm.collectionVariables.set('authToken', json.authToken); }",
                  "if (json.userId) { pm.collectionVariables.set('userId', json.userId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/getuser/{{userId}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/auth/updateuser",
            "header": [
              { "key": "auth-token", "value": "{{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/auth/deleteuser",
            "header": [
              { "key": "auth-token", "value": "{{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/event/getallevents"
          }
        },
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json._id) { pm.collectionVariables.set('eventId', json._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/event/addevent",
            "header": [
              { "key": "auth-token", "value": "{{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Test Event\",\n  \"description\": \"Created via Postman\",\n  \"startdatetime\": \"2026-03-01T10:00:00.000Z\",\n  \"enddatetime\": \"2026-03-01T14:00:00.000Z\",\n  \"location\": \"Online\"\n}"
            }
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/event/getallevents/{{eventId}}"
          }
        },
        {
          "name": "Attend Event (RSVP)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/event/attendevent/{{eventId}}",
            "header": [{ "key": "auth-token", "value": "{{authToken}}" }]
          }
        },
        {
          "name": "Get My Attending Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/event/eventsvisiting",
            "header": [{ "key": "auth-token", "value": "{{authToken}}" }]
          }
        },
        {
          "name": "Get My Hosting Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/event/eventshosting",
            "header": [{ "key": "auth-token", "value": "{{authToken}}" }]
          }
        },
        {
          "name": "Unattend Event",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/event/unattendevent/{{eventId}}",
            "header": [{ "key": "auth-token", "value": "{{authToken}}" }]
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/event/updateevent/{{eventId}}",
            "header": [
              { "key": "auth-token", "value": "{{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Event Title\",\n  \"location\": \"New Location\"\n}"
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/event/deleteevent/{{eventId}}",
            "header": [{ "key": "auth-token", "value": "{{authToken}}" }]
          }
        }
      ]
    }
  ]
}
